{
  "version": 2,
  "functions": {
    "index.php": { "runtime": "vercel-php@0.7.2" },
    "auth/*.php": { "runtime": "vercel-php@0.7.2" },
    "patient/*.php": { "runtime": "vercel-php@0.7.2" },
    "doctor/*.php": { "runtime": "vercel-php@0.7.2" },
    "reception/*.php": { "runtime": "vercel-php@0.7.2" },
    "admin/*.php": { "runtime": "vercel-php@0.7.2" },
    "api/*.php": { "runtime": "vercel-php@0.7.2" }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/auth/(.*)\\.php",
      "dest": "/auth/$1.php"
    },
    {
      "src": "/patient/(.*)\\.php",
      "dest": "/patient/$1.php"
    },
    {
      "src": "/doctor/(.*)\\.php",
      "dest": "/doctor/$1.php"
    },
    {
      "src": "/reception/(.*)\\.php",
      "dest": "/reception/$1.php"
    },
    {
      "src": "/admin/(.*)\\.php",
      "dest": "/admin/$1.php"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}
