{
  "version": 2,
  "builds": [
    {
      "src": "*.php",
      "use": "vercel-php@0.7.2"
    },
    {
      "src": "auth/*.php",
      "use": "vercel-php@0.7.2"
    },
    {
      "src": "patient/*.php",
      "use": "vercel-php@0.7.2"
    },
    {
      "src": "doctor/*.php",
      "use": "vercel-php@0.7.2"
    },
    {
      "src": "reception/*.php",
      "use": "vercel-php@0.7.2"
    },
    {
      "src": "admin/*.php",
      "use": "vercel-php@0.7.2"
    },
    {
      "src": "api/*.php",
      "use": "vercel-php@0.7.2"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/auth/(.+)",
      "dest": "/auth/$1.php"
    },
    {
      "src": "/patient/(.+)",
      "dest": "/patient/$1.php"
    },
    {
      "src": "/doctor/(.+)",
      "dest": "/doctor/$1.php"
    },
    {
      "src": "/reception/(.+)",
      "dest": "/reception/$1.php"
    },
    {
      "src": "/admin/(.+)",
      "dest": "/admin/$1.php"
    },
    {
      "src": "/api(.*)",
      "dest": "/api/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}
